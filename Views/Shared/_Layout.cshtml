<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ChatBot</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ChatBot.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
</head>
<body style="background-color:#262626; height:100vh; margin:0; display:flex;">

    <!-- Menu Lateral -->
    <div class="sidebar" style="width:300px; padding-top:20px; background-color:#0D0D0D; color:white;">
        <h4 class="text-center">CHATBOT</h4>
    </div>

    <!-- Conteúdo principal -->
    <div class="d-flex justify-content-center align-items-center flex-grow-1">
        <div class="d-flex flex-column" style="width: 1000px; gap: 10px;">

            <!-- Área do chat -->
            <div id="naosei" style=" border-radius:10px; min-height: 500px; min-width: 1000px; padding:15px; overflow-y:auto;">
                <main role="main">
                    @RenderBody()
                </main>
            </div>

            <!-- Input -->
            <div id="texto" class="input-container" style="gap:10px;">
                <input type="text" id="input" class="form-control rounded-pill" placeholder="Digite sua pergunta" style="flex-grow:1; height:45px; color: white;">
                <button type="submit" class="btn" id="btnEnviar" style="width:40px; height:40px;">
                    <i class="bi bi-send"></i>
                </button>
            </div>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
